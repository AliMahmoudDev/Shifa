# ===============================================
# متغيرات البيئة المطلوبة للنشر على Vercel
# ===============================================
#
# انسخ هذه القيم إلى Vercel Dashboard > Environment Variables
#
# ===============================================

# 1. قاعدة البيانات (PostgreSQL من Neon)
# احصل عليها من: https://neon.tech
DATABASE_URL="postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/shifa?sslmode=require&pgbouncer=true"

# 2. رابط مباشر لقاعدة البيانات (بدون pgbouncer)
DIRECT_URL="postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/shifa?sslmode=require"

# 3. مفتاح JWT السري (أي نص عشوائي طويل)
JWT_SECRET="change-this-to-a-very-long-random-string-for-security"

# 4. مفتاح Google Gemini API (مجاني!)
# احصل عليه من: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# 5. رابط موقعك على Vercel
NEXT_PUBLIC_APP_URL="https://your-project-name.vercel.app"
